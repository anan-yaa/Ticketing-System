// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

enum SystemRole {
  SUPER_ADMIN
  ADMIN
  CUSTOMER
  L1_ENGINEER
  L2_ENGINEER
  L3_ENGINEER
  MANAGER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  CLOSED
  SCHEDULED
  WORK_IN_PROGRESS
  WAITING_FOR_APPROVAL
  WAITING_FOR_AGENT
  WAITING_FOR_VENDOR
  WAITING_FOR_CUSTOMER
  ON_HOLD
  UNDER_OBSERVATION
  RESOLVED
  TEMPORARILY_CLOSED
}

enum SubStatus {
  WORK_IN_PROGRESS
  WAITING_FOR_APPROVAL
  WAITING_FOR_AGENT
  WAITING_FOR_VENDOR
  WAITING_FOR_CUSTOMER
  ON_HOLD
  UNDER_OBSERVATION
  NONE
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

model User {
  id                 String     @id @default(uuid())
  email              String     @unique
  passwordHash       String
  name               String
  systemRole         SystemRole @default(CUSTOMER) @map("role")
  status             UserStatus @default(ACTIVE)
  mustChangePassword Boolean    @default(true)
  accessTier         String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  // Dynamic Custom Roles relation
  roleId String?
  role   Role?   @relation(fields: [roleId], references: [id])

  // Relations
  tickets      Ticket[]   @relation("TicketCustomerRelation")
  ownedTickets Ticket[]   @relation("TicketOwnerRelation")
  auditLogs    AuditLog[]
  comments     Comment[]

  @@index([email])
  @@index([systemRole])
}

model Role {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  isSystem    Boolean @default(false)

  users       User[]
  permissions RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Permission {
  id     String @id @default(cuid())
  key    String @unique
  label  String
  module String

  roles RolePermission[]
}

model RolePermission {
  id String @id @default(cuid())

  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
}

model Ticket {
  id            String         @id @default(uuid())
  ticketSeq     Int            @unique @default(autoincrement())
  title         String
  description   String
  status        TicketStatus
  statusId      String?
  masterStatus  MasterStatus?  @relation(fields: [statusId], references: [id])
  subStatus     SubStatus      @default(NONE)
  priority      TicketPriority
  category      String?
  source        String         @default("PORTAL")
  customerId    String
  customer      User           @relation("TicketCustomerRelation", fields: [customerId], references: [id])
  ticketOwnerId String?
  ticketOwner   User?          @relation("TicketOwnerRelation", fields: [ticketOwnerId], references: [id])
  slaDeadline   DateTime
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  comments      Comment[]

  // Optional extended telemetry fields
  ticketType       String?
  serviceContract  String?
  firewallCategory String?
  criticality      String?
  customerName     String?
  ticketSource     String?
  timeSpentMin     Int?      @default(0)
  isScopeInScope   Boolean?  @default(true)
  affectedDevice   String?
  deviceIp         String?
  queueId          String?
  slaId            String?
  respondedAt      DateTime?
  closedAt         DateTime?
  isSlaBreached    Boolean?  @default(false)
  ttfrDeadline     DateTime

  // Scheduling telemetry fields
  isRecurring    Boolean?  @default(false)
  executeAt      DateTime?
  cronExpression String?

  // SLA Pause tracking
  slaPausedAt           DateTime?
  lastPausedAt          DateTime?
  accumulatedPausedTime Int?      @default(0)
  resolutionDeadline    DateTime
  firstRespondedAt      DateTime?
  isTtfrBreached        Boolean   @default(false)
  isResolutionBreached  Boolean   @default(false)

  // Fixed instance SLA storage columns
  responseTargetMinutes   Int @default(0) // Tracks the locked response time constraint
  resolutionTargetMinutes Int @default(0) // Tracks the locked resolution time constraint

  scheduledAt      DateTime?
  schedulingReason String?

  // Automation and Archive Flags
  isArchived     Boolean   @default(false)
  archivedAt     DateTime?
  slaTimerActive Boolean   @default(true)

  // Snooze Logic
  preSnoozeStatus String?
  snoozedAt       DateTime?
  snoozedUntil    DateTime?
  resolvedAt      DateTime?
  closedBy        String?

  attachments Attachment[]

  parentId String?
  parent   Ticket?  @relation("TicketToTicket", fields: [parentId], references: [id])
  children Ticket[] @relation("TicketToTicket")

  // 🤖 AI Co-Pilot & Knowledge Base Indexing Telemetry
  isIndexedToVectorDb Boolean   @default(false)
  vectorIndexedAt     DateTime?
  resolutionSummary   String? // Stores the final human-entered solution text block

  // 🤖 Native pgvector High-Dimensional Storage
  embedding           Unsupported("vector(1536)")?
}

model Attachment {
  id        String   @id @default(uuid())
  fileName  String
  filePath  String
  mimeType  String?
  size      Int?
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

enum CommentType {
  CLIENT_REPLY
  AGENT_REPLY
  INTERNAL_NOTE
  SYSTEM_EVENT
}

model Comment {
  id         String      @id @default(uuid())
  content    String
  type       CommentType @default(CLIENT_REPLY)
  isInternal Boolean     @default(false)
  ticketId   String
  ticket     Ticket      @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId   String?
  author     User?       @relation(fields: [authorId], references: [id])
  createdAt  DateTime    @default(now())
}

model AuditLog {
  id            String   @id @default(uuid()) // Or Int @id @default(autoincrement()) depending on preference, using UUID to be consistent with others
  action        String
  performedById String
  performedBy   User     @relation(fields: [performedById], references: [id])
  details       Json
  createdAt     DateTime @default(now())
}

model MasterCategory {
  id             String          @id @default(uuid())
  name           String          @unique
  description    String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  scheduledTasks ScheduledTask[]
}

model MasterType {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MasterStatus {
  id          String   @id @default(uuid())
  name        String   @unique
  label       String
  description String?
  isActive    Boolean  @default(true)
  isSlaPaused Boolean  @default(false)
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tickets Ticket[]
}

model ServiceContract {
  id        String                  @id @default(uuid())
  name      String                  @unique
  isActive  Boolean                 @default(true)
  queues    MasterAssignmentGroup[]
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
}

model MasterAssignmentGroup {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  serviceId String?
  service   ServiceContract? @relation(fields: [serviceId], references: [id])
}

model SlaMatrix {
  id             String   @id @default(uuid())
  priorityTier   String   @unique
  responseTime   Int
  resolutionTime Int
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SlaRule {
  id         String    @id @default(uuid())
  ticketType String    @unique
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  tiers      SlaTier[]
}

model SlaTier {
  id          String  @id @default(uuid())
  level       String
  name        String
  description String?
  respH       Int     @default(0)
  respM       Int     @default(0)
  resH        Int     @default(0)
  resM        Int     @default(0)
  isActive    Boolean @default(true)
  slaRuleId   String
  slaRule     SlaRule @relation(fields: [slaRuleId], references: [id], onDelete: Cascade)
}

model ScheduledTask {
  id           String  @id @default(uuid())
  title        String
  subject      String
  instructions String  @db.Text
  dayOfMonth   Int
  hour         Int
  minute       Int
  isActive     Boolean @default(true)

  // 🔗 Dynamic Relational Link to MasterCategory Table
  masterCategoryId String
  masterCategory   MasterCategory @relation(fields: [masterCategoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
